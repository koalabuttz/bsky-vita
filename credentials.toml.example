# Copy this file to `credentials.toml` (gitignored) and fill in real values.
# Push to the Vita with `make push-creds` (requires VITA_IP env var).
# Lands at ux0:data/BSKY00001/credentials.toml on the device.
#
# Use a Bluesky app password from https://bsky.app/settings/app-passwords.
# NEVER use your main account password.
#
# Phase 1 dev-time only. Phase 2 will replace this with an IME-driven
# login screen and credentials.toml stops being read once a session
# exists at ux0:data/BSKY00001/auth/session.json.

handle = "your-handle.example.com"
app_password = "abcd-1234-efgh-5678"
